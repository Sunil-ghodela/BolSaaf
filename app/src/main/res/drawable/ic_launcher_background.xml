<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Vivid brand gradient: hot pink-red -> magenta -> electric blue -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:color="#FF2E5A" android:offset="0" />
                <item android:color="#B53FCA" android:offset="0.5" />
                <item android:color="#3D7DDB" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom-right vignette for depth -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:alpha="0.18">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="92" android:centerY="100"
                android:gradientRadius="60">
                <item android:color="#0A1530" android:offset="0" />
                <item android:color="#000A1530" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
