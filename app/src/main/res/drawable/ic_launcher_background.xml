<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Brand gradient: vivid red → brand blue -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:color="#E94E5B" android:offset="0" />
                <item android:color="#8A6AA0" android:offset="0.5" />
                <item android:color="#3D7DDB" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle radial glow top-left -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:alpha="0.10">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="32" android:centerY="32"
                android:gradientRadius="70">
                <item android:color="#FFFFFF" android:offset="0" />
                <item android:color="#00FFFFFF" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
